<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.NewPage1"
             Title="Relatório">
    <VerticalStackLayout Spacing="10" Padding="10">
        <Label Text="Relatório por Período" FontSize="20"/>

        <DatePicker x:Name="dtInicio" />
        <DatePicker x:Name="dtFim" />

        <Button Text="Filtrar" Clicked="Button_Clicked"/>

        <CollectionView x:Name="listaProdutos">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Descricao}" />
                            <Label Text="{Binding DataCadastro}" FontSize="12"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>